{
  "name": "techybara",
  "version": "0.3.0",
  "description": "Local-first evidence and completion contracts for Claude Code sessions.",
  "type": "module",
  "bin": {
    "techybara": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "assets/techybara.png"
  ],
  "engines": {
    "node": ">=18.3.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify-pack": "node scripts/verify-pack.mjs",
    "dogfood": "node scripts/dogfood.mjs",
    "dogfood:init": "npm run build && node dist/cli.js init",
    "dogfood:init:dry": "npm run build && node dist/cli.js init --dry-run",
    "dogfood:status": "node dist/cli.js status",
    "dogfood:uninstall": "node dist/cli.js uninstall",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude-code",
    "verification",
    "git",
    "diff",
    "hooks",
    "local-first",
    "ai-agents",
    "completion-contracts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mercydeez/techybara.git"
  },
  "bugs": {
    "url": "https://github.com/mercydeez/techybara/issues"
  },
  "homepage": "https://github.com/mercydeez/techybara#readme",
  "author": "Atharva Soundankar",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
